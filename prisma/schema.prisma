datasource db {
  provider = "postgresql"
}

generator kysely {
  provider = "prisma-kysely"

  output   = "../src/lib/db"
  fileName = "schema.d.ts"
}

model User {
  /// @kyselyType(`u_${string}`)
  id String @id

  username String    @unique
  email    String    @unique
  password String
  sessions Session[]

  server_id String?

  verified_at DateTime?

  pending_email           String?
  email_verify_hash       String?
  email_verify_expires_at DateTime?

  newsletter Boolean @default(false)

  @@index([username])
  @@index([email])
}

model Server {
  /// @kyselyType(`s_${string}`)
  id  String @id
  key String @unique

  name                 String  @unique
  color_code           String
  image_url            String?
  monitoring_image_url String?

  colored_comment String?
  comment         String?

  callback_url String

  ip   String
  port Int

  order Int @unique
}

model News {
  /// @kyselyType(`n_${string}`)
  id String @id

  title     String
  body      String
  image_url String

  is_featured          Boolean
  featured_button_text String?
  featured_button_url  String?

  /// @kyselyType(Timestamp)
  created_at String

  redirect_url String
}

model Notification {
  /// @kyselyType(`nt_${string}`)
  id    String @id
  title String
  body  String

  /// @kyselyType(Timestamp)
  created_at String

  hidden Boolean @default(false)
}

model Session {
  id         String @id
  expires_at Int

  /// @kyselyType(`u_${string}`)
  user_id String
  user    User   @relation(fields: [user_id], references: [id])
}
